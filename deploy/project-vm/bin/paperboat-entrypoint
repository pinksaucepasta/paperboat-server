#!/usr/bin/env bash
set -Eeuo pipefail

runtime_dir="${PAPERBOAT_RUNTIME_DIR:-/var/lib/paperboat}"
log_dir="${PAPERBOAT_LOG_DIR:-/var/log/paperboat}"
workspace="${PAPERBOAT_WORKSPACE:-/workspace}"
readiness_file="${PAPERBOAT_READINESS_FILE:-$runtime_dir/readiness.json}"
bin_dir="${PAPERBOAT_BIN_DIR:-/usr/local/bin}"
child_pids=()
activity_pid=""
activity_restart_count=0
config_sync_pid=""
config_sync_available=false
config_sync_restart_count=0
shutting_down=false
current_stage="initializing"

mkdir -p "$runtime_dir" "$log_dir" "$workspace"
if [ -n "${PAPERBOAT_CONFIG_AGE_IDENTITY:-}" ]; then
  identity_file="${PAPERBOAT_CONFIG_AGE_IDENTITY_FILE:-$runtime_dir/config-age-identity.txt}"
  umask 077
  printf '%s\n' "$PAPERBOAT_CONFIG_AGE_IDENTITY" > "$identity_file"
  chmod 600 "$identity_file"
  unset PAPERBOAT_CONFIG_AGE_IDENTITY
fi
export GIT_ASKPASS="${PAPERBOAT_GIT_ASKPASS:-$bin_dir/paperboat-git-askpass}"
export GIT_TERMINAL_PROMPT=0

log() {
  printf '{"ts":"%s","component":"entrypoint","level":"%s","message":"%s"}\n' \
    "$(date -Iseconds)" "$1" "$2" >&2
}

write_readiness() {
  local state="$1"
  local reason="${2:-}"
  local temporary="$readiness_file.tmp.$$"
  umask 077
  cat > "$temporary" <<EOF
{"state":"$state","reason":"$reason","updated_at":"$(date -Iseconds)"}
EOF
  chmod 600 "$temporary"
  mv -f "$temporary" "$readiness_file"
}

start_stage() {
  current_stage="$1"
  write_readiness starting "$current_stage"
}

record_boot_failure() {
  local status=$?
  trap - ERR
  write_readiness failed "$current_stage"
  log error "boot stage failed: $current_stage"
  exit "$status"
}

require_env() {
  local name="$1"
  if [ -z "${!name:-}" ]; then
    log error "missing required env $name"
    write_readiness failed "missing:$name"
    exit 64
  fi
}

require_env PAPERBOAT_PROJECT_ID
require_env PAPERBOAT_REPOSITORY_URL
require_env PAPERBOAT_AGENTUNNEL_SERVER_URL
require_env PAPERBOAT_AGENTUNNEL_CLIENT_ID
require_env PAPERBOAT_AGENTUNNEL_TUNNEL_ID
require_env "${PAPERBOAT_AGENTUNNEL_TOKEN_ENV:-AGENTUNNEL_MACHINE_TOKEN}"

trap record_boot_failure ERR
start_stage workspace_restore

log info "preparing workspace"
"${PAPERBOAT_PREPARE_WORKSPACE_COMMAND:-$bin_dir/paperboat-prepare-workspace}"

start_stage config_restore
log info "syncing config repo"
"${PAPERBOAT_CONFIG_SYNC_COMMAND:-$bin_dir/paperboat-config-sync}" restore

start_config_sync() {
  "${PAPERBOAT_CONFIG_SYNC_COMMAND:-$bin_dir/paperboat-config-sync}" daemon &
  config_sync_pid=$!
  config_sync_available=true
  log info "config sync daemon started"
}

cleanup() {
  if [ "$shutting_down" = "true" ]; then
    return
  fi
  shutting_down=true
  trap - TERM INT
  log info "shutting down"
  if [ "${#child_pids[@]}" -gt 0 ]; then
    kill "${child_pids[@]}" 2>/dev/null || true
    wait "${child_pids[@]}" 2>/dev/null || true
  fi
  if [ -n "$config_sync_pid" ] && kill -0 "$config_sync_pid" 2>/dev/null; then
    kill -TERM "$config_sync_pid" 2>/dev/null || true
    config_deadline=$((SECONDS + ${PAPERBOAT_CONFIG_SHUTDOWN_DEADLINE_SECONDS:-30} + ${PAPERBOAT_CONFIG_SHUTDOWN_GRACE_SECONDS:-2}))
    while kill -0 "$config_sync_pid" 2>/dev/null && [ "$SECONDS" -lt "$config_deadline" ]; do
      sleep 1
    done
    if kill -0 "$config_sync_pid" 2>/dev/null; then
      kill -KILL "$config_sync_pid" 2>/dev/null || true
      config_sync_available=false
    fi
    if ! wait "$config_sync_pid" 2>/dev/null; then
      config_sync_available=false
    fi
  else
    config_sync_available=false
  fi
  if [ "$config_sync_available" != "true" ]; then
    "${PAPERBOAT_CONFIG_SYNC_COMMAND:-$bin_dir/paperboat-config-sync}" save || true
  fi
  if [ -n "$activity_pid" ] && kill -0 "$activity_pid" 2>/dev/null; then
    kill -TERM "$activity_pid" 2>/dev/null || true
    wait "$activity_pid" 2>/dev/null || true
  fi
}
trap 'cleanup; exit 0' TERM INT
trap cleanup EXIT

start_config_sync

start_stage presets
log info "applying presets"
"${PAPERBOAT_PRESET_APPLY_COMMAND:-$bin_dir/paperboat-apply-presets}"

start_stage papercode_start
log info "starting papercode"
"${PAPERBOAT_PAPERCODE_COMMAND:-$bin_dir/paperboat-start-papercode}" &
papercode_pid=$!
child_pids+=("$papercode_pid")

current_stage="papercode_readiness"
"${PAPERBOAT_WAIT_HTTP_COMMAND:-$bin_dir/paperboat-wait-http}" "${PAPERBOAT_PAPERCODE_LOCAL_URL:-http://127.0.0.1:4099}" 60

# PAPERBOAT_AGENTUNNEL_MODE=required (default) treats an agentunnel exit as
# fatal. The control plane sets "optional" while the hosted HTTP machine-client
# flow is unavailable: the runtime then keeps agentunnel alive with restarts
# and backoff instead of taking the whole VM down with it.
agentunnel_mode="${PAPERBOAT_AGENTUNNEL_MODE:-required}"
agentunnel_restart_count=0
start_agentunnel() {
  "${PAPERBOAT_AGENTUNNEL_COMMAND:-$bin_dir/paperboat-start-agentunnel}" &
  agentunnel_pid=$!
  child_pids+=("$agentunnel_pid")
}

start_stage agentunnel_start
log info "starting agentunnel"
start_agentunnel

current_stage="agentunnel_readiness"
"${PAPERBOAT_WAIT_AGENTUNNEL_COMMAND:-$bin_dir/paperboat-wait-agentunnel}" 60

start_stage activity_reporter
log info "starting activity reporter"
start_activity() {
  "${PAPERBOAT_ACTIVITY_COMMAND:-$bin_dir/paperboat-activity-reporter}" &
  activity_pid=$!
  log info "activity reporter started"
}
start_activity

current_stage="ready"
write_readiness ready "ready"
log info "runtime ready"
route_ready=true

while :; do
  agentunnel_status_file="${PAPERBOAT_AGENTUNNEL_STATUS_FILE:-$runtime_dir/agentunnel-status.json}"
  if grep -q '"status":"connected"' "$agentunnel_status_file" 2>/dev/null; then
    if [ "$route_ready" != "true" ]; then
      write_readiness ready "ready"
      log info "agentunnel route reconnected"
      route_ready=true
    fi
  elif [ "$route_ready" = "true" ]; then
    write_readiness failed "agentunnel_disconnected"
    log error "agentunnel route disconnected"
    route_ready=false
  fi
  for child_pid in "$papercode_pid" "$agentunnel_pid"; do
    if [ -z "$child_pid" ]; then
      continue
    fi
    if [ "$child_pid" = "$agentunnel_pid" ] && [ "$agentunnel_mode" = "optional" ]; then
      continue
    fi
    if ! kill -0 "$child_pid" 2>/dev/null; then
      wait "$child_pid" 2>/dev/null || status=$?
      status="${status:-1}"
      write_readiness failed "process_exit:$status"
      exit "$status"
    fi
  done
  if [ "$agentunnel_mode" = "optional" ] && [ -n "$agentunnel_pid" ] && ! kill -0 "$agentunnel_pid" 2>/dev/null; then
    wait "$agentunnel_pid" 2>/dev/null || agentunnel_status=$?
    agentunnel_status="${agentunnel_status:-1}"
    agentunnel_restart_count=$((agentunnel_restart_count + 1))
    agentunnel_backoff="$agentunnel_restart_count"
    if [ "$agentunnel_backoff" -gt "${PAPERBOAT_AGENTUNNEL_RESTART_MAX_BACKOFF_SECONDS:-30}" ]; then
      agentunnel_backoff="${PAPERBOAT_AGENTUNNEL_RESTART_MAX_BACKOFF_SECONDS:-30}"
    fi
    printf '{"ts":"%s","component":"entrypoint","level":"error","message":"agentunnel exited","status":%s,"restart_count":%s,"backoff_seconds":%s}\n' \
      "$(date -Iseconds)" "$agentunnel_status" "$agentunnel_restart_count" "$agentunnel_backoff" >&2
    sleep "$agentunnel_backoff"
    start_agentunnel
  fi
  if [ -n "$activity_pid" ] && ! kill -0 "$activity_pid" 2>/dev/null; then
    wait "$activity_pid" 2>/dev/null || activity_status=$?
    activity_status="${activity_status:-1}"
    activity_restart_count=$((activity_restart_count + 1))
    backoff="$activity_restart_count"
    if [ "$backoff" -gt "${PAPERBOAT_ACTIVITY_RESTART_MAX_BACKOFF_SECONDS:-30}" ]; then
      backoff="${PAPERBOAT_ACTIVITY_RESTART_MAX_BACKOFF_SECONDS:-30}"
    fi
    printf '{"ts":"%s","component":"entrypoint","level":"error","message":"activity reporter exited","status":%s,"restart_count":%s,"backoff_seconds":%s}\n' \
      "$(date -Iseconds)" "$activity_status" "$activity_restart_count" "$backoff" >&2
    sleep "$backoff"
    start_activity
  fi
  if [ -n "$config_sync_pid" ] && ! kill -0 "$config_sync_pid" 2>/dev/null; then
    config_sync_status=0
    wait "$config_sync_pid" 2>/dev/null || config_sync_status=$?
    config_sync_status="${config_sync_status:-1}"
    config_sync_available=false
    config_sync_restart_count=$((config_sync_restart_count + 1))
    config_sync_backoff="$config_sync_restart_count"
    if [ "$config_sync_backoff" -gt "${PAPERBOAT_CONFIG_RESTART_MAX_BACKOFF_SECONDS:-30}" ]; then
      config_sync_backoff="${PAPERBOAT_CONFIG_RESTART_MAX_BACKOFF_SECONDS:-30}"
    fi
    printf '{"ts":"%s","component":"entrypoint","level":"error","message":"config sync daemon exited","status":%s,"restart_count":%s,"backoff_seconds":%s}\n' \
      "$(date -Iseconds)" "$config_sync_status" "$config_sync_restart_count" "$config_sync_backoff" >&2
    sleep "$config_sync_backoff"
    start_config_sync
  fi
  sleep 1
done
