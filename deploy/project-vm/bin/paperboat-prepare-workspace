#!/usr/bin/env bash
set -Eeuo pipefail

workspace="${PAPERBOAT_WORKSPACE:-/workspace}"
repo_url="${PAPERBOAT_REPOSITORY_URL:?PAPERBOAT_REPOSITORY_URL is required}"
branch="${PAPERBOAT_DEFAULT_BRANCH:-}"

# The repository is cloned into its own folder under the workspace
# (e.g. /workspace/<repo-name>), keeping the workspace root free for
# runtime state (.paperboat) and future projects. The folder name is
# derived from the repository URL unless the control plane overrides it.
project_dir="${PAPERBOAT_PROJECT_DIR:-}"
if [ -z "$project_dir" ]; then
  project_dir="${repo_url%/}"
  project_dir="${project_dir##*/}"
  project_dir="${project_dir%.git}"
fi
target="$workspace/$project_dir"

mkdir -p "$workspace"

if [ ! -d "$target/.git" ]; then
  tmp="$workspace/.paperboat-clone"
  rm -rf "$tmp"
  if [ -n "$branch" ]; then
    git clone --branch "$branch" --single-branch "$repo_url" "$tmp"
  else
    git clone "$repo_url" "$tmp"
  fi
  rm -rf "$target"
  mv "$tmp" "$target"
fi

mkdir -p "$workspace/.paperboat"
