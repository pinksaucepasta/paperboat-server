#!/usr/bin/env bash
set -Eeuo pipefail

local_url="${PAPERBOAT_PAPERCODE_LOCAL_URL:-http://127.0.0.1:4099}"
host_port="${local_url#http://}"
host_port="${host_port#https://}"
host="${host_port%%:*}"
port="${host_port##*:}"

case "$host" in
  127.*|localhost)
    ;;
  *)
    printf 'papercode must bind to loopback, got host %s\n' "$host" >&2
    exit 64
    ;;
esac

case "$port" in
  ''|*[!0-9]*)
    printf 'papercode local URL must include a numeric port\n' >&2
    exit 64
    ;;
esac
if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
  printf 'papercode local port is out of range\n' >&2
  exit 64
fi

export T3CODE_HOST="${PAPERBOAT_PAPERCODE_HOST:-$host}"
export T3CODE_PORT="${PAPERBOAT_PAPERCODE_PORT:-$port}"
case "$T3CODE_HOST" in
  127.*|localhost)
    ;;
  *)
    printf 'PAPERBOAT_PAPERCODE_HOST must be loopback, got %s\n' "$T3CODE_HOST" >&2
    exit 64
    ;;
esac
export T3CODE_HOME="${PAPERBOAT_PAPERCODE_BASE_DIR:-/workspace/.paperboat/papercode}"
export T3CODE_NO_BROWSER=1
export T3CODE_AUTO_BOOTSTRAP_PROJECT_FROM_CWD=1

environment_id="${PAPERBOAT_PAPERCODE_ENVIRONMENT_ID:?missing Paperboat papercode environment id}"
owner_id="${PAPERBOAT_PAPERCODE_OWNER_ID:?missing Paperboat papercode owner id}"
issuer="${PAPERBOAT_PAPERCODE_ISSUER:?missing Paperboat papercode issuer}"
state_dir="$T3CODE_HOME/userdata"
secrets_dir="$state_dir/secrets"

install_value() {
  local path="$1"
  local value="$2"
  local temporary="$path.tmp.$$"
  umask 077
  printf '%s' "$value" > "$temporary"
  chmod 600 "$temporary"
  mv -f "$temporary" "$path"
}

mkdir -p "$secrets_dir"
chmod 700 "$state_dir" "$secrets_dir"
install_value "$state_dir/environment-id" "$environment_id"
install_value "$secrets_dir/cloud-linked-user-id.bin" "$owner_id"
install_value "$secrets_dir/cloud-relay-issuer.bin" "$issuer"

exec node /opt/papercode-server/dist/bin.mjs --no-browser "${PAPERBOAT_WORKSPACE:-/workspace}"
