#!/usr/bin/env bash
set -Eeuo pipefail

url="${1:?url is required}"
timeout="${2:-60}"
deadline=$((SECONDS + timeout))

while [ "$SECONDS" -lt "$deadline" ]; do
  remaining=$((deadline - SECONDS))
  request_timeout=2
  if [ "$remaining" -lt "$request_timeout" ]; then
    request_timeout="$remaining"
  fi
  if curl -fsS --connect-timeout "$request_timeout" --max-time "$request_timeout" "$url" >/dev/null 2>&1; then
    exit 0
  fi
  sleep 1
done

printf 'timed out waiting for %s\n' "$url" >&2
exit 1
