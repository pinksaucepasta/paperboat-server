{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.paperboat.dev/environment/connection-v1.schema.json",
  "title": "Paperboat environment connection descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "issuer", "connectable", "expires_at", "environment", "status", "reason", "retry_after_seconds"],
  "properties": {
    "schema": {"const": "paperboat.environment-connection/v1"},
    "issuer": {"type": "string", "format": "uri", "pattern": "^https://"},
    "connectable": {"type": "boolean"},
    "expires_at": {"type": "string", "format": "date-time"},
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "resource_id", "display_name", "state"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["hosted", "byod"]},
        "resource_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "state": {"enum": ["starting", "ready", "offline", "revoked", "deleted"]},
        "root": {"type": "string", "minLength": 1}
      }
    },
    "helper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "generation"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "generation": {"type": "integer", "minimum": 1}
      }
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["terminal", "herdr", "upload", "preview", "activity"]}
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "auth", "session_id", "thread_id", "terminal_id", "cwd"],
      "properties": {
        "endpoint": {"type": "string", "format": "uri", "pattern": "^wss://"},
        "http_endpoint": {"type": "string", "format": "uri", "pattern": "^https://"},
        "auth": {"$ref": "#/$defs/auth"},
        "session_id": {"type": "string", "minLength": 1},
        "thread_id": {"type": "string", "minLength": 1},
        "terminal_id": {"type": "string", "minLength": 1},
        "cwd": {"type": "string", "minLength": 1}
      }
    },
    "upload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "auth", "max_bytes", "allowed_mime_types", "retention_seconds"],
      "properties": {
        "endpoint": {"type": "string", "format": "uri", "pattern": "^https://"},
        "auth": {"$ref": "#/$defs/auth"},
        "max_bytes": {"type": "integer", "minimum": 1},
        "allowed_mime_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^image/"}
        },
        "retention_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "auth", "expires_at", "state"],
      "properties": {
        "endpoint": {"type": "string", "format": "uri", "pattern": "^https://"},
        "auth": {"$ref": "#/$defs/auth"},
        "expires_at": {"type": "string", "format": "date-time"},
        "public_url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "state": {"enum": ["starting", "ready", "offline", "expired", "removed"]}
      }
    },
    "status": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "retry_after_seconds": {"type": "integer", "minimum": 0}
  },
  "$defs": {
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "expires_at", "scopes"],
      "properties": {
        "method": {"enum": ["websocket_ticket", "bearer"]},
        "ticket": {"type": "string", "minLength": 1},
        "token": {"type": "string", "minLength": 1},
        "expires_at": {"type": "string", "format": "date-time"},
        "scopes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "oneOf": [
        {"required": ["ticket"], "not": {"required": ["token"]}},
        {"required": ["token"], "not": {"required": ["ticket"]}}
      ]
    }
  }
}
